# Data layout:
# - `data/raw/` — HuggingFace cache + scraped HTML; assume contributors obtain separately.
# - `data/processed/`, `data/indices/`, `data/results/` — generated by this repo; safe to commit.
data/raw/

# Embedding index artifacts exceed GitHub's 100MB/file limit — ship via the
# data zip + `scripts/setup_full_index.py`, not git.
data/indices/embeddings/embeddings.npy
data/indices/embeddings/faiss.index

