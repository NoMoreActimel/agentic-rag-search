# =============================================================================
# Option A — Gemini Developer API (Google AI Studio, API key billing)
# =============================================================================
GEMINI_API_KEY=yourkey

# =============================================================================
# Option B — Gemini on Vertex AI (GCP billing / free trial credits)
# =============================================================================
# Uses Application Default Credentials, NOT the AI Studio key above.
# Docs: https://cloud.google.com/vertex-ai/generative-ai/docs/sdks/overview
#
# 1) gcloud auth application-default login
# 2) Enable "Vertex AI API" for your project in Cloud Console
# 3) Uncomment and set:
#
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
#
# Optional alias (either enables Vertex when true):
# GEMINI_USE_VERTEX=1
#
# Optional: HTTP timeout per Gemini request in milliseconds (avoids infinite hangs).
# GEMINI_HTTP_TIMEOUT_MS=600000
#
# Throughput / stability (see config/settings.py — used by GeminiClient + 05_run_experiments)
# GEMINI_RPM_LIMIT=140
# GEMINI_CONCURRENT_LIMIT=6
# GEMINI_RPM_BURST_CAPACITY=12
# GEMINI_MAX_RETRIES=4
# GEMINI_EMBED_MAX_RETRIES=5
# Default --qa-concurrency / --eval-concurrency when omitted on CLI:
# GEMINI_QA_CONCURRENCY_DEFAULT=4
# GEMINI_EVAL_CONCURRENCY=3
